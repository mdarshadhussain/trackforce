// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Employee {
  id          String   @id @default(uuid())
  employeeId  String   @unique // The ID used for login (e.g., TF001)
  firstName   String
  lastName    String
  email       String?  @unique
  password    String
  role        String   @default("EMPLOYEE")
  phone       String?
  designation String?
  status      String   @default("ACTIVE")
  avatar      String?  // Base64 profile image
  plainPassword String? // Store plain text password for visibility in preferences
  
  // Payroll Information
  hourlyRate    Float?   @default(0.0)
  overtimeType  String   @default("MULTIPLIER") // "FIXED" or "MULTIPLIER"
  overtimeValue Float?   @default(1.5)          // e.g., 1.5x or $20.00
  
  // Expanded Identity Manifest
  passportNumber String?
  passportExpiry DateTime?
  passportIssue  DateTime?
  dob            DateTime?
  cvPath         String?
  idDocPath      String?
  
  // Bank Account Details
  bankName          String?
  accountNumber     String?
  accountHolderName String?
  swiftCode         String?
  
  // Relations
  siteId      String? // Relation to Site

  site        Site?       @relation(fields: [siteId], references: [id])
  attendance  Attendance[]
  tracking    Tracking[]
  
  isBiometricEnrolled Boolean @default(false)
  biometricToken      String?  // Store a hash of facial features or public key
  payslips            Payslip[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Site {
  id              String       @id @default(uuid())
  name            String
  location        String
  displayAddress  String?      // Custom address to show on the card
  latitude        Float?       @default(0.0)
  longitude       Float?       @default(0.0)
  geofenceRadius  Float        @default(500) // Configurable radius in meters
  managerName     String?
  workingStartTime String?      @default("07:00")
  lunchStartTime   String?      @default("12:00")
  lunchEndTime     String?      @default("13:00")
  
  // Relations
  employees       Employee[]
  attendance      Attendance[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Holiday {
  id        String   @id @default(uuid())
  date      DateTime @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Attendance {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  siteId      String?
  site        Site?     @relation(fields: [siteId], references: [id])
  date        DateTime  @default(now())
  clockIn     DateTime?  @default(now())
  clockOut    DateTime?
  clockInLat  Float?
  clockInLong Float?
  clockOutLat Float?
  clockOutLong Float?
  biometricProof    String? // Base64 snapshot or verification token (In)
  biometricProofOut String? // Base64 snapshot or verification token (Out)
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED, PRESENT, LATE, ABSENT
  
  // Relations
  breaks      Break[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
  @@index([date])
  @@index([clockIn])
  @@index([status])
}

model Break {
  id           String    @id @default(uuid())
  startTime    DateTime  @default(now())
  endTime      DateTime?
  
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
}


model Tracking {
  id          String   @id @default(uuid())
  latitude    Float
  longitude   Float
  timestamp   DateTime @default(now())
  
  // Relations
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
}

// Enums commented out for SQLite compatibility
// enum Role {
//   ADMIN
//   MANAGER
//   EMPLOYEE
// }

// enum Status {
//   ACTIVE
//   INACTIVE
//   ON_LEAVE
// }

model SecurityAlert {
  id          String   @id @default(uuid())
  type        String   // 'GEOFENCE_VIOLATION', 'BIOMETRIC_MISMATCH'
  message     String
  severity    String   @default("LOW") // LOW, MEDIUM, HIGH
  employeeId  String?
  siteId      String?
  timestamp   DateTime @default(now())
}

model Payslip {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  month           String   // e.g., "2026-05"
  regularHours    Float
  overtimeHours   Float
  grossPay        Float
  netPay          Float
  foodAllowance   Float
  otherAllowance  Float
  taxRate         Float
  taxAmount       Float
  insurance       Float
  advancePayment  Float
  otherDeductions Float
  status          String   @default("GENERATED") // "GENERATED", "FINALIZED", "PAID"
  transactionId   String?
  receiptPath     String?  // File path to the upload transfer receipt
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, month])
}
