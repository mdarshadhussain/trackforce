// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id          String  @id @default(uuid())
  employeeId  String  @unique // The ID used for login (e.g., TF001)
  firstName   String
  lastName    String
  email       String  @unique
  password    String
  role        String  @default("EMPLOYEE") // Changed from Role enum for SQLite
  phone       String?
  designation String?
  status      String  @default("ACTIVE") // Changed from Status enum for SQLite
  avatar      String? // Base64 profile image

  // Relations
  siteId     String?
  site       Site?        @relation(fields: [siteId], references: [id])
  attendance Attendance[]
  tracking   Tracking[]

  isBiometricEnrolled Boolean @default(false)
  biometricToken      String? // Store a hash of facial features or public key

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Site {
  id          String  @id @default(uuid())
  name        String
  location    String
  latitude    Float?  @default(0.0)
  longitude   Float?  @default(0.0)
  managerName String?

  // Relations
  employees Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id             String    @id @default(uuid())
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id])
  date           DateTime  @default(now())
  clockIn        DateTime  @default(now())
  clockOut       DateTime?
  clockInLat     Float?
  clockInLong    Float?
  clockOutLat    Float?
  clockOutLong   Float?
  biometricProof String? // Base64 snapshot or verification token
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED, PRESENT, LATE, ABSENT

  // Relations
  breaks Break[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Break {
  id        String    @id @default(uuid())
  startTime DateTime  @default(now())
  endTime   DateTime?

  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
}

model Tracking {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  timestamp DateTime @default(now())

  // Relations
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
}

// Enums commented out for SQLite compatibility
// enum Role {
//   ADMIN
//   MANAGER
//   EMPLOYEE
// }

// enum Status {
//   ACTIVE
//   INACTIVE
//   ON_LEAVE
// }

model SecurityAlert {
  id         String   @id @default(uuid())
  type       String // 'GEOFENCE_VIOLATION', 'BIOMETRIC_MISMATCH'
  message    String
  severity   String   @default("LOW") // LOW, MEDIUM, HIGH
  employeeId String?
  siteId     String?
  timestamp  DateTime @default(now())
}
